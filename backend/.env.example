# RakshaRide Backend - Environment Variables
# ------------------------------------------------------------------------------
# Copy this file to .env and fill in your values.
# NEVER commit the actual .env file - it contains secrets.
#
#   cp backend/.env.example backend/.env

# ----- Server -----------------------------------------------------------------
PORT=5000
NODE_ENV=development

# ----- MongoDB ----------------------------------------------------------------
# Local:  mongodb://localhost:27017/gigshield
# Atlas:  mongodb+srv://<user>:<password>@cluster.mongodb.net/gigshield
MONGODB_URI=mongodb://localhost:27017/gigshield

# ----- Auth / API Security ----------------------------------------------------
# Set a long random value in production.
JWT_SECRET_KEY=change_me_to_a_secure_random_secret
# Enable JWT auth middleware for protected routes.
ENFORCE_AUTH=false
# Prototype auth endpoint credentials.
AUTH_DEMO_USERNAME=admin
# Prefer hash in real setups (bcrypt hash), keep plain password only for local demos.
AUTH_DEMO_PASSWORD_HASH=
AUTH_DEMO_PASSWORD=admin123

# ----- OpenWeatherMap API -----------------------------------------------------
# Get a free key at: https://openweathermap.org/api
# One key works for both weather and air pollution endpoints.
WEATHER_API_KEY=your_openweathermap_api_key_here
POLLUTION_API_KEY=your_openweathermap_api_key_here
WEATHER_API_BASE_URL=https://api.openweathermap.org/data/2.5
POLLUTION_API_BASE_URL=https://api.openweathermap.org/data/2.5

# ----- Razorpay (add when ready for payments) ---------------------------------
# Dashboard -> Settings -> API Keys: https://dashboard.razorpay.com/app/keys
# Leave blank to run in STUB mode (mock payouts - safe for development/demo)
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
# Required for Payouts (claim disbursement):
# Dashboard -> Payouts -> Settings -> Account Number
RAZORPAY_ACCOUNT_NUMBER=

# Payout execution mode (used by payoutService):
# - mock: log/mock payouts (recommended for local dev/demo)
# - disabled: skip payout execution
PAYOUT_MODE=mock

# Premium collection flow toggle:
# - false: users can subscribe and get policy access immediately (no payment step)
# - true: enables Razorpay order + verify endpoints
ENABLE_PREMIUM_PAYMENT_FLOW=false

# ----- Python AI Service Integration ------------------------------------------
# Backend calls these endpoints to auto-assign city risk category at registration
# and to enrich fraud scoring during claim verification.
AI_SERVICE_BASE_URL=http://localhost:5001
AI_REQUEST_TIMEOUT_MS=2500


