# â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
# Copy this file to .env and fill in your values.
# NEVER commit the actual .env file â€” it contains secrets.
#
#   cp backend/.env.example backend/.env

# â”€â”€â”€ Server â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
PORT=5000
NODE_ENV=development

# â”€â”€â”€ MongoDB â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
# Local:  mongodb://localhost:27017/raksharide
# Atlas:  mongodb+srv://<user>:<password>@cluster.mongodb.net/raksharide
MONGODB_URI=mongodb://localhost:27017/raksharide

# â”€â”€â”€ Auth / API Security â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
# Set a long random value in production.
JWT_SECRET_KEY=change_me_to_a_secure_random_secret
# Enable JWT auth middleware for protected routes.
ENFORCE_AUTH=false
# Prototype auth endpoint credentials.
AUTH_DEMO_USERNAME=admin
# Prefer hash in real setups (bcrypt hash), keep plain password only for local demos.
AUTH_DEMO_PASSWORD_HASH=
AUTH_DEMO_PASSWORD=admin123

# â”€â”€â”€ OpenWeatherMap API â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
# Get a free key at: https://openweathermap.org/api
# One key works for both weather and air pollution endpoints.
WEATHER_API_KEY=your_openweathermap_api_key_here
POLLUTION_API_KEY=your_openweathermap_api_key_here
WEATHER_API_BASE_URL=https://api.openweathermap.org/data/2.5
POLLUTION_API_BASE_URL=https://api.openweathermap.org/data/2.5

# â”€â”€â”€ Razorpay (add when ready for payments) â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
# Dashboard â†’ Settings â†’ API Keys: https://dashboard.razorpay.com/app/keys
# Leave blank to run in STUB mode (mock payouts â€” safe for development/demo)
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
# Required for Payouts (claim disbursement):
# Dashboard â†’ Payouts â†’ Settings â†’ Account Number
RAZORPAY_ACCOUNT_NUMBER=

# Payout execution mode (used by payoutService):
# - mock: log/mock payouts (recommended for local dev/demo)
# - disabled: skip payout execution
PAYOUT_MODE=mock

# Premium collection flow toggle:
# - false: users can subscribe and get policy access immediately (no payment step)
# - true: enables Razorpay order + verify endpoints
ENABLE_PREMIUM_PAYMENT_FLOW=false

# â”€â”€â”€ Python AI Service Integration â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
# Backend calls these endpoints to auto-assign city risk category at registration
# and to enrich fraud scoring during claim verification.
AI_SERVICE_BASE_URL=http://localhost:5001
AI_REQUEST_TIMEOUT_MS=2500

