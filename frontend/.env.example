# GigShield Frontend — Environment Variables
# ────────────────────────────────────────────
# Copy this file to .env and fill in your values.
# All frontend env vars MUST be prefixed with VITE_ to be exposed to the browser.
#
#   cp frontend/.env.example frontend/.env

# ─── Backend API URL ──────────────────────────────────────────────────────────
# In development the Vite proxy handles /api → localhost:5000 automatically.
# Set this only if deploying to a different host.
VITE_API_BASE_URL=

# ─── AI API URL ────────────────────────────────────────────────────────────────
# In development the Vite proxy handles /ai → localhost:5001 automatically.
# Set this only if frontend is hosted separately from the AI service.
VITE_AI_BASE_URL=

# ─── Razorpay (frontend checkout widget) ──────────────────────────────────────
# This is the PUBLIC key (safe to expose in browser).
# The SECRET key MUST stay in the backend .env only.
VITE_RAZORPAY_KEY_ID=

# ─── Admin access (frontend gate for /admin route) ────────────────────────────
# Leave empty to disable the gate in local development.
VITE_ADMIN_ACCESS_KEY=
